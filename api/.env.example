# Server
SERVER_HOST=0.0.0.0
SERVER_SECURE=false # Set to true if you want to use HTTPS (requires SSL_CERT_FILE and SSL_KEY_FILE)
SERVER_PORT=2705
SERVER_DOMAIN=localhost
# last SERVER_CORS_ORIGINS url is your local IP address, so you can test on other devices in your network (e.g. smartphone)
SERVER_CORS_ORIGINS=https://<YOUR_DOMAIN>,http://localhost:5173,http://192.168.178.46:5173
SERVER_CORS_MAXAGE=43200

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=embox
DB_USER=embox
DB_PASSWORD=embox
DB_SYSTEM_USER=

# Storage
# "local" for dev without LuckyCloud, "luckycloud" for production
STORAGE_ADAPTER=luckycloud
STORAGE_LOCAL_DIR=./dev-storage
STORAGE_URL=https://sync.luckycloud.de/api2
STORAGE_USERNAME=
STORAGE_PASSWORD=
STORAGE_REPO_ID=

# Auth
AUTH_ACCESS_JWT_SECRET=
AUTH_REFRESH_JWT_SECRET=
AUTH_ACCESS_COOKIE_EXPIRATION=3600
AUTH_REFRESH_COOKIE_EXPIRATION=4320000
AUTH_LOGIN_TOKEN_EXPIRATION=600

# CSRF
CSRF_SECRET=
CSRF_MAXAGE=3600

# Email (Gmail SMTP)
GMAIL_HOST=smtp.gmail.com
GMAIL_PORT=587
GMAIL_FROM=
GMAIL_APP_PASSWORD=
TOKEN_EMAIL_SUBJECT=Your Login Token

# Router / Logging
ROUTER_RUNTIME=release
ROUTER_LOG_OUTPUT=stdout
ROUTER_LOG_MAX_SIZE=100
ROUTER_LOG_MAX_BACKUPS=7
ROUTER_LOG_MAX_AGE=30
ROUTER_LOG_COMPRESS=true
ROUTER_AUTH_RATE_LIMIT=10
